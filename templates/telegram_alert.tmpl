{{- /* ─────────────────────────────────────────────────────────────
   Alert template
   ───────────────────────────────────────────────────────────── */ -}}

{{- if gt .PartCount 1 -}}
<b>📦 Part {{ .PartIndex }} of {{ .PartCount }}</b>

{{ end -}}

{{- /* ── Header: status · environment · counts ── */ -}}
{{- $envName := env .CommonLabels -}}
{{ statusIcon .Status }}{{ if $envName }} {{ envIcon $envName }} <b>{{ upper $envName }}</b>{{ end }}
{{ .FiringCount }} firing{{ if .ResolvedCount }} · {{ .ResolvedCount }} resolved{{ end }}{{ if .TotalAlerts }} · {{ .TotalAlerts }} total{{ end }}

{{- /* ── Group context (only labels shared by every alert) ── */ -}}
{{- with filterLabels .CommonLabels }}
<i>{{ joinPairs . }}</i>
{{- end }}
{{- if .Message }}

{{ .Message }}
{{- end }}

{{- /* ── Per-alert blocks ─────────────────────────────────── */ -}}
{{ range $i, $a := .Alerts }}
─────────────────────────────
{{ severityIcon $a.Severity }} <b>{{ orDash $a.Name }}</b>
{{- if $a.Severity }} · {{ $a.Severity }}{{ end -}}
{{- if eq $a.Status "resolved" }} · ✅ resolved{{ end }}

{{- /* Summary first — the headline for humans */ -}}
{{- if $a.Summary }}
{{ $a.Summary }}
{{- end }}

{{- /* Description only if it actually adds info */ -}}
{{- if and $a.Description (ne $a.Description $a.Summary) }}

{{ truncate $a.Description 500 }}
{{- end }}

{{- /* Identity: where exactly is this happening */ -}}
{{- $where := filterLabels $a.Labels }}
{{- if $where }}

<b>Where:</b> <b>{{ joinPairs $where }}</b>
{{- end }}

{{- /* Value: actual measurement that triggered the rule */ -}}
{{- if $a.ValueString }}
<b>Value:</b> <b><code>{{ $a.ValueString }}</code></b>
{{- end }}

{{- /* Time: when it started, how long it's been going */ -}}
{{- if not (isZeroTime $a.StartsAt) }}
<b>Since:</b> <b>{{ formatTime $a.StartsAt }} ({{ since $a.StartsAt }})</b>
{{- end }}
{{- if and (eq $a.Status "resolved") (not (isZeroTime $a.EndsAt)) }}
<b>Resolved:</b> {{ formatTime $a.EndsAt }} (lasted {{ duration $a.StartsAt $a.EndsAt }})
{{- end }}

{{- /* Actionable links: only those that exist, on one line */ -}}
{{- $links := list -}}
{{- if index $a.Annotations "runbook_url" }}{{ $links = append $links (printf "<a href=\"%s\">📕 runbook</a>" (index $a.Annotations "runbook_url")) }}{{ end -}}
{{- if $a.GeneratorURL }}{{ $links = append $links (printf "<a href=\"%s\">📊 graph</a>" $a.GeneratorURL) }}{{ end -}}
{{- if $a.DashboardURL }}{{ $links = append $links (printf "<a href=\"%s\">📈 dashboard</a>" $a.DashboardURL) }}{{ end -}}
{{- if $a.PanelURL }}{{ $links = append $links (printf "<a href=\"%s\">🔍 panel</a>" $a.PanelURL) }}{{ end -}}
{{- if $a.SilenceURL }}{{ $links = append $links (printf "<a href=\"%s\">🔕 silence</a>" $a.SilenceURL) }}{{ end -}}
{{- if $links }}

{{ join $links "  ·  " }}
{{- end }}
{{- end }}

{{- /* ── Footer: only if alerts were truncated ────────────── */ -}}
{{- if gt .TotalAlerts (len .Alerts) }}

<i>… and {{ sub .TotalAlerts (len .Alerts) }} more alerts in this group</i>
{{- end }}
